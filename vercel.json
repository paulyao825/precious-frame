{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/index.js": {
      "maxDuration": 300,
      "includeFiles": "server/dist/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/media/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
