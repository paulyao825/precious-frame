# Copy to .env — keys are read via the apiKeyEnv names in topshot.config.json
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=

# AWS (judge.provider = "bedrock" and/or aws.s3Bucket in topshot.config.json).
# Any SDK default-chain source works too (~/.aws, SSO, roles).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
TOPSHOT_S3_BUCKET=
