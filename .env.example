# Copy to .env. Never commit real values.
MOONSHOT_API_KEY=

# Optional overrides. Defaults target Moonshot's Kimi K2.6 endpoint.
VISION_PROVIDER=kimi
VISION_MODEL=kimi-k2.6
VISION_BASE_URL=https://api.moonshot.cn/v1

# Optional Gemini final review and user-triggered AI blur repair.
GEMINI_API_KEY=
GEMINI_FINAL_MODEL=gemini-3.5-flash
NANO_BANANA_MODEL=gemini-3.1-flash-image
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
